{
  "name": "tidy-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Tidy desktop app (internal distribution)",
  "author": "tidy",
  "license": "SEE LICENSE IN LICENSE",
  "main": "src/main.cjs",
  "scripts": {
    "dev": "electron .",
    "generate:icons": "node scripts/generate-icons.mjs",
    "prepare:resources": "node scripts/prepare-resources.mjs",
    "dist": "npm run generate:icons && npm run prepare:resources && electron-builder",
    "dist:mac": "npm run generate:icons && npm run prepare:resources && electron-builder --mac"
  },
  "dependencies": {
    "fs-extra": "^11.3.3"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.tidy.app",
    "productName": "Tidy",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**",
      "package.json"
    ],
    "extraResources": [
      { "from": "bundle/server", "to": "server" },
      { "from": "bundle/client", "to": "client" },
      { "from": "bundle/ai-service", "to": "ai-service" },
      { "from": "bundle/node", "to": "node" }
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": ["nsis", "zip"]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": ["AppImage", "deb", "rpm", "tar.gz"]
    }
  }
}



